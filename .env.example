# =============================================================================
# app.aimeserias.ro – variabile de mediu
# Copiază acest fișier ca .env.local și completează valorile.
# .env.local nu se comite în git.
# =============================================================================

# --- API Meserias (backend) --------------------------------------------------
# URL-ul serverului api.aimeserias.ro (dev: http://localhost:5000)
NEXT_PUBLIC_API_URL=http://localhost:5000
API_URL=http://localhost:5000

# --- Autentificare JWT -------------------------------------------------------
# Numele cookie-ului cu tokenul JWT returnat de POST /login
AUTH_COOKIE_NAME=meserias_jwt
NEXT_PUBLIC_AUTH_COOKIE_NAME=meserias_jwt

# Domeniu partajat între aimeserias.ro și app.aimeserias.ro (doar producție)
# AUTH_COOKIE_DOMAIN=.aimeserias.ro
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.aimeserias.ro

# --- Site public (marketing) -------------------------------------------------
# URL-ul frontendului aimeserias.ro (linkuri sidebar către Meseriași, Proiecte etc.)
NEXT_PUBLIC_SITE_URL=https://aimeserias.ro

# --- Media / assets (opțional) -----------------------------------------------
# NEXT_PUBLIC_ASSETS_URL=https://assets.onedu.ro

# --- SSO ONedu (legacy – nu mai este folosit pentru login) -------------------
# AUTH_SERVER_URL=http://localhost:4000
# AUTH_APP_TOKEN=
# NEXT_PUBLIC_AUTH_SERVER_URL=http://localhost:4000
# NEXT_PUBLIC_AUTH_APP_TOKEN=
